{
  "name": "@memizy/plugin-sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for building Memizy plugins.",
  "type": "module",
  "main": "./dist/memizy-sdk.umd.cjs",
  "module": "./dist/memizy-sdk.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/memizy-sdk.js",
      "require": "./dist/memizy-sdk.umd.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memizy/plugin-sdk.git"
  },
  "keywords": [
    "memizy",
    "plugin",
    "sdk",
    "oqse",
    "education"
  ],
  "author": "Memizy Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/memizy/plugin-sdk/issues"
  },
  "homepage": "https://github.com/memizy/plugin-sdk#readme",
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  }
}